<div class="event-card">

  <div class="event-card-image">
    <img src="{{ event.image|default('https://via.placeholder.com/600x400') }}" alt="event">
  </div>

  <div class="event-card-body">

    <div class="event-card-club">
      <span class="event-card-club-dot"></span>
      {{ event.club|default('INSAT Club') }}
    </div>

    <h3 class="event-card-title">
      {{ event.title|default('Event Title') }}
    </h3>

    <p class="event-card-desc">
      {{ event.description|default('Event description goes here...') }}
    </p>

    <div class="event-card-meta">
      <div class="event-meta-item">📅 {{ event.date|default('Date TBD') }}</div>
      <div class="event-meta-item">📍 {{ event.location|default('Campus') }}</div>
    </div>

  </div>

  <div class="event-card-footer">
    <span class="price-badge free">Free</span>

    <a href="#" class="btn btn-primary btn-sm">
      View
    </a>
  </div>

</div>