<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{% block title %}INSAT Events{% endblock %}</title>

    <link rel="stylesheet" href="{{ asset('styles/main.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/components.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/layout.css') }}">

    {% block styles %}{% endblock %}
</head>

<body data-page="{% block page %}{% endblock %}">

{% block body %}{% endblock %}

<script src="{{ asset('scripts/api.js') }}"></script>
<script src="{{ asset('scripts/auth.js') }}"></script>
<script src="{{ asset('scripts/app.js') }}"></script>

{% block scripts %}{% endblock %}

</body>
</html>